# ============================================
# SOCIAL MEDIA PUBLISHER - CONFIGURATION
# ============================================

# --------------------------------------------
# TELEGRAM (самый простой для начала)
# --------------------------------------------
# Получить токен: @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# ID канала (например: @mychannel или -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel_id
# ID для личных статусов (твой user_id)
TELEGRAM_USER_ID=your_user_id

# --------------------------------------------
# META (Instagram + Facebook + Threads)
# --------------------------------------------
# https://developers.facebook.com/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Long-lived access token
META_ACCESS_TOKEN=your_meta_access_token
# Instagram Business Account ID
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id
# Facebook Page ID
FACEBOOK_PAGE_ID=your_facebook_page_id

# --------------------------------------------
# YOUTUBE
# --------------------------------------------
# https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
# ID канала YouTube
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# --------------------------------------------
# TIKTOK
# --------------------------------------------
# https://developers.tiktok.com/
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_OPEN_ID=your_tiktok_open_id

# --------------------------------------------
# WHATSAPP BUSINESS API
# --------------------------------------------
# https://business.facebook.com/wa/manage/home/
# Или через провайдер: 360dialog, Twilio, WATI
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_CHANNEL_ID=your_channel_id
WHATSAPP_COMMUNITY_ID=your_community_id

# --------------------------------------------
# BROWSER AUTOMATION (для платформ без API)
# --------------------------------------------
# Использовать браузерную автоматизацию (true/false)
USE_BROWSER_AUTOMATION=true

# Instagram Web (для Stories если нет API)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Facebook Web (для Stories и Reels если нет API)
FACEBOOK_EMAIL=your_facebook_email
FACEBOOK_PASSWORD=your_facebook_password

# TikTok Web (если нет API доступа)
TIKTOK_EMAIL=your_tiktok_email
TIKTOK_PASSWORD=your_tiktok_password

# Telegram Web (номер телефона для входа)
TELEGRAM_PHONE=+77001234567

# Режим headless (true = без показа браузера, false = видимый браузер)
BROWSER_HEADLESS=false

# --------------------------------------------
# CONFIGURATION
# --------------------------------------------
# Путь к папке с баннерами
BANNERS_PATH=../
# Логирование (DEBUG, INFO, ERROR)
LOG_LEVEL=INFO
# Задержка между публикациями (секунды)
PUBLISH_DELAY=5
