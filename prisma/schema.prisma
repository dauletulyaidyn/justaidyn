generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String    @id @default(cuid())
  googleSub                    String?   @unique
  email                        String    @unique
  name                         String
  firstName                    String
  lastName                     String    @default("")
  profileTitle                 String?
  profileLabel                 String?
  shortBio                     String?
  organization                 String?
  location                     String?
  website                      String?
  picture                      String?
  passwordHash                 String?
  passwordUpdatedAt            DateTime?
  role                         Role      @default(CLIENT)
  paddleSubscriptionId         String?
  paddleSubscriptionStatus     String?
  paddleSubscribedAt           DateTime?
  paddleSubscriptionUpdatedAt  DateTime?
  thinkerSubscriptionId        String?
  thinkerSubscriptionStatus    String?
  thinkerSubscribedAt          DateTime?
  thinkerSubscriptionUpdatedAt DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  lastLoginAt                  DateTime  @default(now())

  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  desktopOtcs         DesktopOtc[]
  apiTokens           ApiToken[]
  postViews           PostView[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model OAuthState {
  state              String   @id
  mode               String
  desktopRedirectUri String?
  createdAt          DateTime @default(now())

  @@map("oauth_states")
}

model DesktopOtc {
  id          String    @id @default(cuid())
  token       String    @unique
  userId      String
  redirectUri String
  codeChallenge String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("desktop_otcs")
}

model ApiToken {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_tokens")
}

model PasswordResetToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Post {
  id          String    @id @default(cuid())
  platform    Platform
  title       String
  slug        String
  excerpt     String    @default("")
  content     String    @default("")
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  views       PostView[]

  @@unique([platform, slug])
  @@index([platform, published])
  @@map("posts")
}

model PostView {
  id              String   @id @default(cuid())
  postId          String
  userId          String?
  visitorId       String
  path            String
  referrer        String?
  userAgent       String?
  ipHash          String?
  durationSeconds Int      @default(0)
  startedAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId, startedAt])
  @@index([visitorId])
  @@index([userId])
  @@map("post_views")
}

enum Role {
  CLIENT
  SUPERADMIN
}

enum Platform {
  SKILLSMINDS
  NOFACETHINKER
}
