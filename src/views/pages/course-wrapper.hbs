<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    {{#if description}}<meta name="description" content="{{description}}">{{/if}}
    <link rel="icon" type="image/png" href="/favicon.png?v=20260331c">
    <link rel="shortcut icon" type="image/png" href="/favicon.png?v=20260331c">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/templatemo-first-portfolio-style.css" rel="stylesheet">
    <link href="/static/styles/platform.css" rel="stylesheet">
    <link href="/css/ai-agents-course-pages.css" rel="stylesheet">
  </head>
  <body class="course-page platform-body" data-default-lang="ru" data-page-key="{{coursePageKey}}" data-content-src="/data/course-pages.json">
    <section class="preloader">
      <div class="spinner">
        <span class="spinner-rotate"></span>
      </div>
    </section>
    {{> header}}
    <main id="coursePageContent"></main>
    {{> footer}}
    <script src="/js/jquery.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
    <script src="/js/jquery.sticky.js"></script>
    <script src="/js/click-scroll.js"></script>
    <script src="/js/custom.js?v=20260422-menuall"></script>
    <script src="/data/course-pages-data.js?v=20260420-course-groups"></script>
    <script src="/js/course-pages.js?v=20260422-course-lang"></script>
  </body>
  </html>
