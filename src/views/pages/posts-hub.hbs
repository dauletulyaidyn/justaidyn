<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <meta name="description" content="{{description}}">
  <link rel="icon" type="image/png" href="/favicon.png?v=20260331c">
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/templatemo-first-portfolio-style.css" rel="stylesheet">
  <link href="/static/styles/legal.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(rgba(240,242,250,0.92), rgba(240,242,250,0.97)), url("/images/portrait-happy-excited-man-holding-laptop-computer.png") center / cover no-repeat fixed; }
    .posts-shell { max-width: 900px; margin: 0 auto; padding: 110px 24px 72px; }
    .posts-header { margin-bottom: 36px; }
    .posts-header h1 { font-size: clamp(1.8rem,4vw,2.6rem); margin-bottom: 8px; }
    .posts-header p { color: #5e6c79; }
    .post-card { background: rgba(255,255,255,0.93); border: 1px solid rgba(24,35,44,0.1); border-radius: 12px; padding: 28px 32px; margin-bottom: 18px; display: block; text-decoration: none; color: inherit; transition: box-shadow 0.15s, transform 0.15s; }
    .post-card:hover { box-shadow: 0 8px 32px rgba(18,35,52,0.1); transform: translateY(-2px); color: inherit; }
    .post-card-platform { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #535da1; background: rgba(83,93,161,0.1); border-radius: 99px; padding: 2px 10px; display: inline-block; margin-bottom: 12px; }
    .post-card h2 { font-size: 1.2rem; margin: 0 0 8px; }
    .post-card p { color: #5e6c79; font-size: 0.92rem; margin: 0; line-height: 1.6; }
    .post-card-meta { font-size: 0.78rem; color: #8a96a0; margin-top: 12px; }
    .empty-state { text-align: center; padding: 60px 0; color: #8a96a0; }
    .empty-state i { font-size: 2.5rem; display: block; margin-bottom: 12px; }
    .paywall-card { background: rgba(255,255,255,0.95); border: 2px solid #535da1; border-radius: 14px; padding: 48px 40px; text-align: center; }
    .paywall-card h2 { font-size: 1.5rem; margin-bottom: 12px; }
    .paywall-card p { color: #5e6c79; margin-bottom: 24px; }
    .btn-subscribe-thinker { display: inline-flex; align-items: center; gap: 8px; padding: 13px 28px; border-radius: 10px; background: #535da1; color: #fff; font-weight: 700; font-size: 1rem; border: none; cursor: pointer; transition: background 0.15s; }
    .btn-subscribe-thinker:hover { background: #3d4680; }
    @media (max-width: 991px) { .posts-shell { padding-top: 205px; } }
    @media (max-width: 600px) { .post-card { padding: 20px; } .paywall-card { padding: 32px 20px; } }
  </style>
</head>
<body>
  {{> header}}

  <div class="posts-shell">
    <div class="posts-header">
      <h1>{{heroTitle}}</h1>
      {{#if description}}<p>{{description}}</p>{{/if}}
      {{#if (eq pageKey 'posts-hub')}}
        {{#if currentUser.role}}
          {{#if (eq platform 'nofacethinker')}}
            {{#unless isPaywall}}
            <a href="/admin/posts/new?platform=nofacethinker" class="btn btn-sm btn-outline-secondary" style="font-size:0.8rem" {{#unless (eq currentUser.role 'superadmin')}}style="display:none"{{/unless}}>+ New post</a>
            {{/unless}}
          {{else}}
            <a href="/admin/posts/new?platform=skillsminds" class="btn btn-sm btn-outline-secondary" style="font-size:0.8rem;{{#unless (eq currentUser.role 'superadmin')}}display:none{{/unless}}">+ New post</a>
          {{/if}}
        {{/if}}
      {{/if}}
    </div>

    {{#if isPaywall}}
    <div class="paywall-card">
      <i class="bi bi-lock-fill" style="font-size:2.5rem;color:#535da1;display:block;margin-bottom:16px"></i>
      <h2 data-en="Exclusive content for subscribers" data-ru="Эксклюзивный контент для подписчиков" data-kk="Жазылушыларға арналған эксклюзивті контент">Exclusive content for subscribers</h2>
      <p data-en="Subscribe to no Face Thinker to get access to all posts. $3.90/month with a 7-day free trial." data-ru="Подпишитесь на no Face Thinker и получите доступ ко всем постам. $3.90/мес, 7 дней бесплатно." data-kk="no Face Thinker-ге жазылып, барлық постқа қол жеткізіңіз. Айына $3.90, 7 күн тегін.">Subscribe to no Face Thinker to get access to all posts. $3.90/month with a 7-day free trial.</p>
      <button class="btn-subscribe-thinker" onclick="openThinkerCheckout()">
        <i class="bi bi-star"></i>
        <span data-en="Start 7-day Free Trial" data-ru="Начать 7 дней бесплатно" data-kk="7 күн тегін бастау">Start 7-day Free Trial</span>
      </button>
    </div>
    {{else}}
      {{#if posts.length}}
        {{#each posts}}
        <a class="post-card" href="/{{../platform}}/post/{{this.slug}}">
          <span class="post-card-platform">{{#if (eq ../platform 'skillsminds')}}Skills & Minds{{else}}no Face Thinker{{/if}}</span>
          <h2>{{this.title}}</h2>
          {{#if this.excerpt}}<p>{{this.excerpt}}</p>{{/if}}
          <div class="post-card-meta">{{this.publishedAt}}</div>
        </a>
        {{/each}}
      {{else}}
        <div class="empty-state">
          <i class="bi bi-file-earmark-text"></i>
          <p data-en="No posts yet." data-ru="Постов пока нет." data-kk="Посттар әлі жоқ.">No posts yet.</p>
        </div>
      {{/if}}
    {{/if}}
  </div>

  {{> footer}}
  <script src="/js/jquery.min.js"></script>
  <script src="/js/bootstrap.min.js"></script>
  <script src="/js/jquery.sticky.js"></script>
  <script src="/js/custom.js?v=20260428-profile-i18n"></script>
  {{#if isPaywall}}
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <script>
    Paddle.Environment.set('sandbox');
    Paddle.Initialize({
      token: 'test_16c22427a493b4298c916610736',
      eventCallback: function(event) {
        if (event.name === 'checkout.completed') {
          fetch('/api/paddle/thinker/verify-checkout', { method: 'POST' })
            .then(function() { window.location.reload(); })
            .catch(function() { window.location.reload(); });
        }
      }
    });
    function openThinkerCheckout() {
      Paddle.Checkout.open({ items: [{ priceId: '{{thinkerPriceId}}', quantity: 1 }] });
    }
  </script>
  {{/if}}
</body>
</html>
