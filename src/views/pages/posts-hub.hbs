<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <meta name="description" content="{{description}}">
  <link rel="canonical" href="https://justaidyn.com/{{platform}}">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{title}}">
  <meta property="og:description" content="{{description}}">
  <meta property="og:url" content="https://justaidyn.com/{{platform}}">
  <meta property="og:site_name" content="JustAidyn">
  {{#if posts.[0].coverImage}}<meta property="og:image" content="https://justaidyn.com{{posts.[0].coverImage}}">{{/if}}
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{title}}">
  <meta name="twitter:description" content="{{description}}">
  {{#if posts.[0].coverImage}}<meta name="twitter:image" content="https://justaidyn.com{{posts.[0].coverImage}}">{{/if}}
  {{#if isPaywall}}<meta name="robots" content="noindex">{{/if}}
  <link rel="icon" type="image/png" href="/favicon.png?v=20260331c">
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/magnific-popup.css" rel="stylesheet">
  <link href="/css/templatemo-first-portfolio-style.css" rel="stylesheet">
  <style>
    html { scroll-padding-top: 155px; }
    body { background: linear-gradient(rgba(240,242,250,0.92), rgba(240,242,250,0.97)), url("/images/portrait-happy-excited-man-holding-laptop-computer.png") center / cover no-repeat fixed; }
    .posts-page { padding: 160px 0 72px; }
    @media (max-width: 991px) { .posts-page { padding-top: 205px; } }
    #intro, #posts, #subscribe, #contact { scroll-margin-top: 155px; }
    @media (max-width: 991px) { html { scroll-padding-top: 210px; } #intro, #posts, #subscribe, #contact { scroll-margin-top: 210px; } }
    .hub-intro { background: rgba(255,255,255,0.96); border: 1px solid rgba(24,35,44,0.1); border-radius: 16px; padding: 28px; margin-bottom: 28px; }
    .hub-intro h1 { font-size: clamp(1.7rem,3.5vw,2.5rem); margin: 0 0 12px; }
    .hub-intro-lead { color: #4d5c68; max-width: 850px; line-height: 1.75; margin: 0; font-size: 1rem; }
    .blog-layout { display: grid; grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.85fr); gap: 30px; align-items: start; margin-bottom: 34px; }
    .blog-featured { background: rgba(255,255,255,0.96); border: 1px solid rgba(24,35,44,0.1); border-radius: 16px; overflow: hidden; color: inherit; display: block; text-decoration: none; }
    .blog-featured:hover { color: inherit; box-shadow: 0 12px 42px rgba(18,35,52,0.14); }
    .blog-featured-media { width: 100%; aspect-ratio: 16 / 9; background: #e8edf5; overflow: hidden; }
    .blog-featured-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .blog-featured-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg,#535da1 0%,#14b78a 100%); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.65); font-size: 3.4rem; }
    .blog-featured-body { padding: 26px 30px 30px; }
    .blog-meta { color: #7a8691; font-size: 0.82rem; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
    .blog-category { color: #535da1; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
    .blog-featured h2 { font-size: clamp(1.55rem,3vw,2.35rem); line-height: 1.18; margin: 0 0 12px; }
    .blog-featured p { color: #4d5c68; line-height: 1.7; margin: 0; max-width: 760px; }
    .blog-sidebar { background: rgba(255,255,255,0.96); border: 1px solid rgba(24,35,44,0.1); border-radius: 16px; padding: 22px; }
    .blog-sidebar h2 { font-size: 1rem; letter-spacing: 0.08em; text-transform: uppercase; color: #535da1; margin: 0 0 12px; }
    .blog-side-list { display: grid; gap: 0; counter-reset: latest-posts; }
    .blog-side-item { display: grid; grid-template-columns: 34px minmax(0, 1fr); gap: 12px; padding: 15px 0; border-top: 1px solid rgba(24,35,44,0.09); text-decoration: none; color: inherit; }
    .blog-side-item:first-child { border-top: 0; }
    .blog-side-index { font-size: 1.55rem; line-height: 1; font-weight: 800; color: rgba(83,93,161,0.25); }
    .blog-side-index::before { counter-increment: latest-posts; content: counter(latest-posts); }
    .blog-side-item h3 { font-size: 0.98rem; line-height: 1.36; margin: 0 0 6px; }
    .blog-side-item span { color: #7a8691; font-size: 0.78rem; }
    .blog-side-item:hover h3 { color: #535da1; }
    .blog-section-title { border-top: 2px solid rgba(24,35,44,0.14); padding-top: 16px; margin-bottom: 22px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .blog-section-title h2 { margin: 0; font-size: 1.35rem; }
    .blog-post-list { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px; }
    .blog-list-item { display: grid; grid-template-rows: auto 1fr; background: rgba(255,255,255,0.96); border: 1px solid rgba(24,35,44,0.1); border-radius: 14px; overflow: hidden; color: inherit; text-decoration: none; min-height: 100%; }
    .blog-list-item:hover { color: inherit; box-shadow: 0 10px 34px rgba(18,35,52,0.12); }
    .blog-list-media { aspect-ratio: 16 / 10; background: #e8edf5; }
    .blog-list-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .blog-list-placeholder { width: 100%; height: 100%; min-height: 150px; background: linear-gradient(135deg,#535da1 0%,#7a84c8 100%); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.6); font-size: 2.3rem; }
    .blog-list-body { padding: 20px 22px 22px; }
    .blog-list-body h3 { font-size: 1.18rem; line-height: 1.34; margin: 0 0 8px; }
    .blog-list-body p { color: #5e6c79; line-height: 1.62; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .blog-card-tags { display: flex; gap: 7px; flex-wrap: wrap; margin-top: 12px; }
    .blog-card-tag { color: #535da1; background: rgba(83,93,161,0.08); border-radius: 999px; padding: 4px 9px; font-size: 0.75rem; font-weight: 800; }
    .blog-controls { background: rgba(255,255,255,0.96); border: 1px solid rgba(24,35,44,0.1); border-radius: 14px; padding: 18px; margin-bottom: 22px; display: grid; grid-template-columns: minmax(220px, 1fr) 190px; gap: 14px; }
    .blog-control-field { border: 1px solid rgba(24,35,44,0.15); border-radius: 10px; background: #fff; color: #18232c; min-height: 44px; padding: 0 14px; font-size: 0.92rem; width: 100%; }
    .blog-tag-filter { display: flex; gap: 8px; flex-wrap: wrap; margin: 0 0 20px; }
    .blog-tag-btn { border: 1px solid rgba(83,93,161,0.22); background: rgba(83,93,161,0.08); color: #535da1; border-radius: 999px; padding: 7px 12px; font-size: 0.82rem; font-weight: 700; cursor: pointer; }
    .blog-tag-btn.active, .blog-tag-btn:hover { background: #535da1; color: #fff; }
    .blog-pagination { display: flex; gap: 8px; justify-content: center; align-items: center; flex-wrap: wrap; margin-top: 24px; }
    .blog-page-btn { width: 38px; height: 38px; border-radius: 999px; border: 1px solid rgba(83,93,161,0.25); background: #fff; color: #535da1; font-weight: 800; cursor: pointer; }
    .blog-page-btn.active, .blog-page-btn:hover { background: #535da1; color: #fff; }
    .blog-results-note { color: #7a8691; font-size: 0.86rem; margin: 0; }
    .posts-header { margin-bottom: 32px; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .posts-header h1 { font-size: clamp(1.6rem,3.5vw,2.4rem); margin: 0; }
    .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    .post-card { background: rgba(255,255,255,0.95); border: 1px solid rgba(24,35,44,0.1); border-radius: 14px; overflow: hidden; display: block; text-decoration: none; color: inherit; transition: box-shadow 0.18s, transform 0.18s; }
    .post-card:hover { box-shadow: 0 10px 40px rgba(18,35,52,0.13); transform: translateY(-3px); color: inherit; }
    .post-card-img { width: 100%; height: 200px; object-fit: cover; display: block; background: #e8edf5; }
    .post-card-img-placeholder { width: 100%; height: 200px; background: linear-gradient(135deg,#535da1 0%,#7a84c8 100%); display: flex; align-items: center; justify-content: center; }
    .post-card-img-placeholder i { font-size: 3rem; color: rgba(255,255,255,0.5); }
    .post-card-body { padding: 20px 24px 22px; }
    .post-card-platform { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #535da1; background: rgba(83,93,161,0.1); border-radius: 99px; padding: 2px 10px; display: inline-block; margin-bottom: 10px; }
    .post-card-body h2 { font-size: 1.05rem; margin: 0 0 8px; line-height: 1.4; }
    .post-card-body p { color: #5e6c79; font-size: 0.87rem; margin: 0; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .post-card-lock { position: absolute; top: 12px; right: 12px; background: rgba(83,93,161,0.9); color: #fff; border-radius: 99px; padding: 3px 10px; font-size: 0.72rem; font-weight: 700; }
    .post-card-wrap { position: relative; }
    .empty-state { text-align: center; padding: 60px 0; color: #8a96a0; grid-column: 1/-1; }
    .empty-state i { font-size: 2.5rem; display: block; margin-bottom: 12px; }
    .paywall-wrap { grid-column: 1/-1; }
    .paywall-card { background: rgba(255,255,255,0.97); border: 2px solid #535da1; border-radius: 16px; padding: 56px 48px; text-align: center; max-width: 560px; margin: 0 auto; }
    .paywall-card h2 { font-size: 1.5rem; margin-bottom: 12px; }
    .paywall-card p { color: #5e6c79; margin-bottom: 28px; line-height: 1.7; }
    .btn-thinker { display: inline-flex; align-items: center; gap: 8px; padding: 13px 30px; border-radius: 10px; background: #535da1; color: #fff; font-weight: 700; font-size: 1rem; border: none; cursor: pointer; transition: background 0.15s; }
    .btn-thinker:hover { background: #3d4680; }
    @media (max-width: 991px) { .blog-layout { grid-template-columns: 1fr; } }
    @media (max-width: 991px) { .blog-post-list { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 700px) { .blog-post-list { grid-template-columns: 1fr; } .blog-list-media { min-height: 190px; } .blog-controls { grid-template-columns: 1fr; } }
    @media (max-width: 600px) { .paywall-card { padding: 36px 24px; } .posts-grid { grid-template-columns: 1fr; } .hub-intro { padding: 22px; } .blog-featured-body { padding: 22px; } .blog-sidebar { padding: 18px; } }
  </style>
</head>
<body>
  <section class="preloader"><div class="spinner"><span class="spinner-rotate"></span></div></section>
  <nav class="navbar navbar-expand-lg navbar-split">
    <div class="container">
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#phNav" aria-controls="phNav" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
      <a class="navbar-brand mx-auto mx-lg-0" href="/">JustAidyn</a>
      <div class="d-flex align-items-center d-lg-none"><a class="custom-btn btn" href="https://wa.me/77769889889" target="_blank" rel="noopener">WhatsApp</a></div>
      <div class="collapse navbar-collapse" id="phNav">
        <div class="navbar-split-layout w-100">
          <div class="navbar-top-contact d-none d-lg-flex">
            <div class="navbar-top-contact-left"></div>
            <div class="navbar-top-tools">
              <div class="language-selector navbar-top-lang language-flags" role="group" aria-label="Language selector">
                <button type="button" class="lang-flag-btn" data-lang-option="kk" onclick="changeLanguage('kk')" aria-label="Kazakh" title="Kazakh">KK</button>
                <button type="button" class="lang-flag-btn" data-lang-option="en" onclick="changeLanguage('en')" aria-label="English" title="English">EN</button>
                <button type="button" class="lang-flag-btn" data-lang-option="ru" onclick="changeLanguage('ru')" aria-label="Russian" title="Russian">RU</button>
              </div>
              <div class="navbar-top-auth-links"></div>
            </div>
          </div>
          <ul class="navbar-nav ms-lg-0 nav-row-primary">
            {{#if (eq platform 'skillsminds')}}
            <li class="nav-item"><a class="nav-link active" href="/skillsminds" data-en="Home" data-ru="Главная" data-kk="Басты">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#intro" data-en="Intro" data-ru="О проекте" data-kk="Жоба туралы">Intro</a></li>
            <li class="nav-item"><a class="nav-link" href="#posts" data-en="Posts" data-ru="Посты" data-kk="Посттар">Posts</a></li>
            <li class="nav-item"><a class="nav-link" href="#contact" data-en="Contact" data-ru="Контакты" data-kk="Байланыс">Contact</a></li>
            {{else}}
            <li class="nav-item"><a class="nav-link active" href="/nofacethinker" data-en="Home" data-ru="Главная" data-kk="Басты">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#posts" data-en="Posts" data-ru="Посты" data-kk="Посттар">Posts</a></li>
            <li class="nav-item"><a class="nav-link" href="#subscribe" data-en="Subscribe" data-ru="Подписка" data-kk="Жазылым">Subscribe</a></li>
            <li class="nav-item"><a class="nav-link" href="#contact" data-en="Contact" data-ru="Контакты" data-kk="Байланыс">Contact</a></li>
            {{/if}}
          </ul>
        </div>
      </div>
    </div>
  </nav>

  <div id="subscribed-banner" style="display:none;background:#14b78a;color:#fff;text-align:center;padding:14px 20px;font-weight:600;font-size:1rem;">
    <span data-en="✓ Subscription activated! Welcome to no Face Thinker." data-ru="✓ Подписка активирована! Добро пожаловать в no Face Thinker." data-kk="✓ Жазылым белсендірілді! no Face Thinker-ге қош келдіңіз.">✓ Subscription activated! Welcome to no Face Thinker.</span>
  </div>
  <script>
    if (new URLSearchParams(window.location.search).get('subscribed') === '1') {
      document.getElementById('subscribed-banner').style.display = 'block';
      history.replaceState(null, '', window.location.pathname);
    }
  </script>
  <div class="posts-page">
    <div class="container">
      {{#if (eq platform 'skillsminds')}}
      <section class="hub-intro" id="intro">
        <h1>Skills and Minds Hub</h1>
        <p class="hub-intro-lead"
          data-en="Skills and Minds Hub is a project about skill development in any direction. Posts are grouped by hashtags so each reader can follow the topics and learning paths they need."
          data-ru="Skills and Minds Hub - проект о развитии навыков в любом направлении. Посты будут группироваться по хэштегам, чтобы читатель мог быстро найти нужную тему и свой путь развития."
          data-kk="Skills and Minds Hub - кез келген бағыттағы дағдыларды дамытуға арналған жоба. Материалдар хэштегтер арқылы топтастырылып, оқырман өзіне керек тақырыптарды оңай таба алады.">
          Skills and Minds Hub is a project about skill development in any direction. Posts are grouped by hashtags so each reader can follow the topics and learning paths they need.
        </p>
      </section>
      {{/if}}

      {{#if (eq platform 'skillsminds')}}
        {{#if posts.length}}
        <section class="blog-layout" id="posts" aria-label="Featured posts">
          {{#each posts}}
            {{#if @first}}
            <a class="blog-featured" href="/{{../platform}}/post/{{this.slug}}">
              <div class="blog-featured-media">
                {{#if this.coverImage}}
                  <img src="{{this.coverImage}}" alt="{{this.title}}" loading="lazy" width="900" height="506">
                {{else}}
                  <div class="blog-featured-placeholder"><i class="bi bi-journal-text"></i></div>
                {{/if}}
              </div>
              <div class="blog-featured-body">
                <div class="blog-meta"><span class="blog-category">Skills & Minds</span><span>{{formatDate this.publishedAt}}</span><span>{{this.viewCount}} views</span></div>
                <h2>{{this.title}}</h2>
                {{#if this.excerpt}}<p>{{this.excerpt}}</p>{{/if}}
              </div>
            </a>
            {{/if}}
          {{/each}}

          <aside class="blog-sidebar" aria-label="Latest posts">
            <h2 data-en="Latest" data-ru="Последние" data-kk="Соңғы">Latest</h2>
            <div class="blog-side-list">
              {{#each posts}}
              <a class="blog-side-item" href="/{{../platform}}/post/{{this.slug}}" data-latest-index="{{@index}}">
                <span class="blog-side-index" aria-hidden="true"></span>
                <span class="blog-side-content">
                  <h3>{{this.title}}</h3>
                  <span>{{formatDate this.publishedAt}} · {{this.viewCount}} views</span>
                </span>
              </a>
              {{/each}}
            </div>
          </aside>
        </section>

        <section aria-label="All posts">
          <div class="blog-section-title">
            <h2 data-en="All posts" data-ru="Все посты" data-kk="Барлық посттар">All posts</h2>
            <p class="blog-results-note" id="skills-results-note"></p>
            {{#if (eq currentUser.role 'superadmin')}}
            <a href="/admin/posts/new?platform={{platform}}" class="btn btn-sm btn-outline-secondary">+ New post</a>
            {{/if}}
          </div>
          <div class="blog-controls" aria-label="Post controls">
            <input class="blog-control-field" id="skills-post-search" type="search"
              data-en-placeholder="Search posts"
              data-ru-placeholder="Поиск постов"
              data-kk-placeholder="Посттарды іздеу"
              placeholder="Search posts">
            <select class="blog-control-field" id="skills-post-sort" aria-label="Sort posts">
              <option value="newest" data-en="Newest first" data-ru="Сначала новые" data-kk="Алдымен жаңалары">Newest first</option>
              <option value="oldest" data-en="Oldest first" data-ru="Сначала старые" data-kk="Алдымен ескілері">Oldest first</option>
              <option value="title" data-en="Title A-Z" data-ru="Название A-Z" data-kk="Атауы A-Z">Title A-Z</option>
            </select>
          </div>
          <div class="blog-tag-filter" id="skills-tag-filter" aria-label="Hashtag filter"></div>
          <div class="blog-post-list">
            {{#each posts}}
            <a class="blog-list-item" href="/{{../platform}}/post/{{this.slug}}" data-title="{{this.title}}" data-excerpt="{{this.excerpt}}" data-date="{{this.publishedAt}}">
              <div class="blog-list-media">
                {{#if this.coverImage}}
                  <img src="{{this.coverImage}}" alt="{{this.title}}" loading="lazy" width="320" height="220">
                {{else}}
                  <div class="blog-list-placeholder"><i class="bi bi-file-earmark-text"></i></div>
                {{/if}}
              </div>
              <div class="blog-list-body">
                <div class="blog-meta"><span class="blog-category">Skills & Minds</span><span>{{formatDate this.publishedAt}}</span><span>{{this.viewCount}} views</span></div>
                <h3>{{this.title}}</h3>
                {{#if this.excerpt}}<p>{{this.excerpt}}</p>{{/if}}
              </div>
            </a>
            {{/each}}
          </div>
          <div class="empty-state" id="skills-filter-empty" style="display:none;">
            <i class="bi bi-search"></i>
            <p data-en="No posts match the selected filters." data-ru="По выбранным фильтрам постов нет." data-kk="Таңдалған сүзгілер бойынша посттар жоқ.">No posts match the selected filters.</p>
          </div>
          <div class="blog-pagination" id="skills-pagination" aria-label="Post pagination"></div>
        </section>
        {{else}}
          <div class="empty-state" id="posts">
            <i class="bi bi-file-earmark-text"></i>
            <p>No posts yet.</p>
          </div>
        {{/if}}
      {{else}}
        <div class="posts-header" id="posts">
          <h1>{{heroTitle}}</h1>
          {{#if (eq currentUser.role 'superadmin')}}
            {{#unless isPaywall}}
            <a href="/admin/posts/new?platform={{platform}}" class="btn btn-sm btn-outline-secondary">+ New post</a>
            {{/unless}}
          {{/if}}
        </div>

        <div class="posts-grid">
          {{#if posts.length}}
            {{#each posts}}
            <div class="post-card-wrap">
              <a class="post-card" href="/{{../platform}}/post/{{this.slug}}">
                {{#if this.coverImage}}
                  <img class="post-card-img" src="{{this.coverImage}}" alt="{{this.title}}" loading="lazy" width="400" height="200">
                {{else}}
                  <div class="post-card-img-placeholder"><i class="bi bi-file-earmark-text"></i></div>
                {{/if}}
                <div class="post-card-body">
                  <span class="post-card-platform">no Face Thinker</span>
                  <h2>{{this.title}}</h2>
                  <div class="blog-meta"><span>{{this.viewCount}} views</span></div>
                  {{#if this.excerpt}}<p>{{this.excerpt}}</p>{{/if}}
                </div>
              </a>
              {{#if ../isPaywall}}<span class="post-card-lock"><i class="bi bi-lock-fill"></i> Premium</span>{{/if}}
            </div>
            {{/each}}
          {{else}}
            <div class="empty-state">
              <i class="bi bi-file-earmark-text"></i>
              <p>No posts yet.</p>
            </div>
          {{/if}}

        {{#if isPaywall}}
        <div class="paywall-wrap" id="subscribe">
          <div class="paywall-card">
            <i class="bi bi-star-fill" style="font-size:2.2rem;color:#535da1;display:block;margin-bottom:16px"></i>
            <h2 data-en="Subscribe to read all posts" data-ru="Подпишитесь для полного доступа" data-kk="Барлық постқа қол жеткізу үшін жазылыңыз">Subscribe to read all posts</h2>
            <p data-en="Get full access to all no Face Thinker posts. $3.90/month with a 7-day free trial." data-ru="Получите полный доступ ко всем постам no Face Thinker. $3.90/мес, 7 дней бесплатно." data-kk="no Face Thinker постарының барлығына қол жеткізіңіз. Айына $3.90, 7 күн тегін.">Get full access to all no Face Thinker posts. $3.90/month with a 7-day free trial.</p>
