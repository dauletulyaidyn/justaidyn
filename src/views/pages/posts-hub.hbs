  {{#if (eq platform 'skillsminds')}}
  <script>
    (function() {
      var pageSize = 6;
      var currentPage = 1;
      var activeTag = 'all';
      var searchInput = document.getElementById('skills-post-search');
      var sortSelect = document.getElementById('skills-post-sort');
      var tagFilter = document.getElementById('skills-tag-filter');
      var pagination = document.getElementById('skills-pagination');
      var emptyState = document.getElementById('skills-filter-empty');
      var resultsNote = document.getElementById('skills-results-note');
      var posts = Array.prototype.slice.call(document.querySelectorAll('.blog-list-item'));
      var latestItems = Array.prototype.slice.call(document.querySelectorAll('.blog-side-item'));
      var tagSet = new Set();

      latestItems.forEach(function(item, index) {
        item.style.display = index < 6 ? 'grid' : 'none';
      });

      function normalize(value) {
        return (value || '').toLowerCase().trim();
      }

      function extractTags(text) {
        var matches = (text || '').match(/#[\p{L}\p{N}_-]+/gu) || [];
        return matches.map(function(tag) { return tag.toLowerCase(); });
      }

      posts.forEach(function(post) {
        var text = [post.dataset.title, post.dataset.excerpt].join(' ');
        var tags = extractTags(text);
        post.dataset.tags = tags.join(' ');
        tags.forEach(function(tag) { tagSet.add(tag); });
        if (tags.length) {
          var body = post.querySelector('.blog-list-body');
          var tagWrap = document.createElement('div');
          tagWrap.className = 'blog-card-tags';
          tagWrap.innerHTML = tags.map(function(tag) {
            return '<span class="blog-card-tag">' + tag + '</span>';
          }).join('');
          body.appendChild(tagWrap);
        }
      });

      function label(en, ru, kk) {
        var lang = localStorage.getItem('selectedLanguage') || 'kk';
        return lang === 'ru' ? ru : lang === 'kk' ? kk : en;
      }

      function renderTags() {
        if (!tagFilter) return;
        var tags = ['all'].concat(Array.from(tagSet).sort());
        tagFilter.innerHTML = tags.map(function(tag) {
          var text = tag === 'all' ? label('All', 'Все', 'Барлығы') : tag;
          return '<button class="blog-tag-btn' + (tag === activeTag ? ' active' : '') + '" type="button" data-tag="' + tag + '">' + text + '</button>';
        }).join('');
        tagFilter.querySelectorAll('.blog-tag-btn').forEach(function(button) {
          button.addEventListener('click', function() {
            activeTag = button.dataset.tag || 'all';
            currentPage = 1;
            update();
          });
        });
      }

      function filteredPosts() {
        var query = normalize(searchInput && searchInput.value);
        var items = posts.filter(function(post) {
          var searchable = normalize([post.dataset.title, post.dataset.excerpt, post.dataset.tags].join(' '));
          var tagMatch = activeTag === 'all' || (post.dataset.tags || '').split(' ').indexOf(activeTag) !== -1;
          return tagMatch && (!query || searchable.indexOf(query) !== -1);
        });

        items.sort(function(a, b) {
          var sort = sortSelect ? sortSelect.value : 'newest';
          if (sort === 'title') return (a.dataset.title || '').localeCompare(b.dataset.title || '');
          var aTime = Date.parse(a.dataset.date || '') || 0;
          var bTime = Date.parse(b.dataset.date || '') || 0;
          return sort === 'oldest' ? aTime - bTime : bTime - aTime;
        });
        return items;
      }

      function renderPagination(totalPages) {
        if (!pagination) return;
        if (totalPages <= 1) {
          pagination.innerHTML = '';
          return;
        }
        var buttons = [];
        for (var page = 1; page <= totalPages; page += 1) {
          buttons.push('<button class="blog-page-btn' + (page === currentPage ? ' active' : '') + '" type="button" data-page="' + page + '">' + page + '</button>');
        }
        pagination.innerHTML = buttons.join('');
        pagination.querySelectorAll('.blog-page-btn').forEach(function(button) {
          button.addEventListener('click', function() {
            currentPage = Number(button.dataset.page) || 1;
            update();
          });
        });
      }

      function update() {
        var items = filteredPosts();
        var totalPages = Math.max(1, Math.ceil(items.length / pageSize));
        currentPage = Math.min(currentPage, totalPages);
        var start = (currentPage - 1) * pageSize;
        var visible = new Set(items.slice(start, start + pageSize));

        if (searchInput) searchInput.placeholder = label('Search posts', 'Поиск постов', 'Посттарды іздеу');
        posts.forEach(function(post) {
          post.style.display = visible.has(post) ? 'grid' : 'none';
        });
        if (emptyState) emptyState.style.display = items.length ? 'none' : 'block';
        if (resultsNote) {
          resultsNote.textContent = items.length
            ? label(items.length + ' posts', items.length + ' постов', items.length + ' пост')
            : label('No posts', 'Нет постов', 'Пост жоқ');
        }
        renderPagination(totalPages);
        renderTags();
      }

      if (searchInput) searchInput.addEventListener('input', function() { currentPage = 1; update(); });
      if (sortSelect) sortSelect.addEventListener('change', function() { currentPage = 1; update(); });
      document.querySelectorAll('[data-lang-option]').forEach(function(button) {
        button.addEventListener('click', function() { setTimeout(update, 0); });
      });
      renderTags();
      update();
    })();
  </script>
  {{/if}}
  {{#if isPaywall}}
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <script>
    function getCookie(name) {
      return document.cookie.split(';').map(function(part) { return part.trim(); }).reduce(function(value, part) {
        return part.indexOf(name + '=') === 0 ? decodeURIComponent(part.slice(name.length + 1)) : value;
      }, '');
    }

    Paddle.Environment.set('sandbox');
    Paddle.Initialize({
      token: 'test_16c22427a493b4298c916610736',
      eventCallback: function(event) {
        if (event.name === 'checkout.completed') {
          fetch('/api/paddle/thinker/verify-checkout', { method: 'POST', headers: { 'X-CSRF-Token': getCookie('ja_csrf') } })
            .then(function() { window.location.href = '/nofacethinker?subscribed=1'; })
            .catch(function() { window.location.reload(); });
        }
      }
    });
    function openThinkerCheckout() {
      Paddle.Checkout.open({
        items: [{ priceId: '{{thinkerPriceId}}', quantity: 1 }],
        customer: { email: '{{currentUser.email}}' },
        settings: { allowQuantity: false }
      });
    }
    var alreadySubscribed = {{#if (or (eq currentUser.thinkerSubscriptionStatus 'active') (eq currentUser.thinkerSubscriptionStatus 'trialing'))}}true{{else}}false{{/if}};
    if (new URLSearchParams(window.location.search).get('checkout') === '1') {
      history.replaceState(null, '', window.location.pathname);
      if (!alreadySubscribed) {
        openThinkerCheckout();
      }
    }
  </script>
  {{/if}}
