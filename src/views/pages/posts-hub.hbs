<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <meta name="description" content="{{description}}">
  <link rel="canonical" href="https://justaidyn.com/{{platform}}">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{title}}">
  <meta property="og:description" content="{{description}}">
  <meta property="og:url" content="https://justaidyn.com/{{platform}}">
  <meta property="og:site_name" content="JustAidyn">
  {{#if posts.[0].coverImage}}<meta property="og:image" content="https://justaidyn.com{{posts.[0].coverImage}}">{{/if}}
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{title}}">
  <meta name="twitter:description" content="{{description}}">
  {{#if posts.[0].coverImage}}<meta name="twitter:image" content="https://justaidyn.com{{posts.[0].coverImage}}">{{/if}}
  {{#if isPaywall}}<meta name="robots" content="noindex">{{/if}}
  <link rel="icon" type="image/png" href="/favicon.png?v=20260331c">
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/magnific-popup.css" rel="stylesheet">
  <link href="/css/templatemo-first-portfolio-style.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(rgba(240,242,250,0.92), rgba(240,242,250,0.97)), url("/images/portrait-happy-excited-man-holding-laptop-computer.png") center / cover no-repeat fixed; }
    .posts-page { padding: 160px 0 72px; }
    @media (max-width: 991px) { .posts-page { padding-top: 205px; } }
    .posts-header { margin-bottom: 32px; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .posts-header h1 { font-size: clamp(1.6rem,3.5vw,2.4rem); margin: 0; }
    .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    .post-card { background: rgba(255,255,255,0.95); border: 1px solid rgba(24,35,44,0.1); border-radius: 14px; overflow: hidden; display: block; text-decoration: none; color: inherit; transition: box-shadow 0.18s, transform 0.18s; }
    .post-card:hover { box-shadow: 0 10px 40px rgba(18,35,52,0.13); transform: translateY(-3px); color: inherit; }
    .post-card-img { width: 100%; height: 200px; object-fit: cover; display: block; background: #e8edf5; }
    .post-card-img-placeholder { width: 100%; height: 200px; background: linear-gradient(135deg,#535da1 0%,#7a84c8 100%); display: flex; align-items: center; justify-content: center; }
    .post-card-img-placeholder i { font-size: 3rem; color: rgba(255,255,255,0.5); }
    .post-card-body { padding: 20px 24px 22px; }
    .post-card-platform { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #535da1; background: rgba(83,93,161,0.1); border-radius: 99px; padding: 2px 10px; display: inline-block; margin-bottom: 10px; }
    .post-card-body h2 { font-size: 1.05rem; margin: 0 0 8px; line-height: 1.4; }
    .post-card-body p { color: #5e6c79; font-size: 0.87rem; margin: 0; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .post-card-lock { position: absolute; top: 12px; right: 12px; background: rgba(83,93,161,0.9); color: #fff; border-radius: 99px; padding: 3px 10px; font-size: 0.72rem; font-weight: 700; }
    .post-card-wrap { position: relative; }
    .empty-state { text-align: center; padding: 60px 0; color: #8a96a0; grid-column: 1/-1; }
    .empty-state i { font-size: 2.5rem; display: block; margin-bottom: 12px; }
    .paywall-wrap { grid-column: 1/-1; }
    .paywall-card { background: rgba(255,255,255,0.97); border: 2px solid #535da1; border-radius: 16px; padding: 56px 48px; text-align: center; max-width: 560px; margin: 0 auto; }
    .paywall-card h2 { font-size: 1.5rem; margin-bottom: 12px; }
    .paywall-card p { color: #5e6c79; margin-bottom: 28px; line-height: 1.7; }
    .btn-thinker { display: inline-flex; align-items: center; gap: 8px; padding: 13px 30px; border-radius: 10px; background: #535da1; color: #fff; font-weight: 700; font-size: 1rem; border: none; cursor: pointer; transition: background 0.15s; }
    .btn-thinker:hover { background: #3d4680; }
    @media (max-width: 600px) { .paywall-card { padding: 36px 24px; } .posts-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <section class="preloader"><div class="spinner"><span class="spinner-rotate"></span></div></section>
  <nav class="navbar navbar-expand-lg navbar-split">
    <div class="container">
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#phNav" aria-controls="phNav" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
      <a class="navbar-brand mx-auto mx-lg-0" href="/">JustAidyn</a>
      <div class="d-flex align-items-center d-lg-none"><a class="custom-btn btn" href="https://wa.me/77769889889" target="_blank" rel="noopener">WhatsApp</a></div>
      <div class="collapse navbar-collapse" id="phNav">
        <div class="navbar-split-layout w-100">
          <div class="navbar-top-contact d-none d-lg-flex">
            <div class="navbar-top-contact-left"></div>
            <div class="navbar-top-tools">
              <div class="language-selector navbar-top-lang language-flags"></div>
              <div class="navbar-top-auth-links"></div>
            </div>
          </div>
          <ul class="navbar-nav ms-lg-0 nav-row-primary"></ul>
        </div>
      </div>
    </div>
  </nav>

  <div class="posts-page">
    <div class="container">
      <div class="posts-header">
        <h1>{{heroTitle}}</h1>
        {{#if (eq currentUser.role 'superadmin')}}
          {{#unless isPaywall}}
          <a href="/admin/posts/new?platform={{platform}}" class="btn btn-sm btn-outline-secondary">+ New post</a>
          {{/unless}}
        {{/if}}
      </div>

      <div class="posts-grid">
        {{#if posts.length}}
          {{#each posts}}
          <div class="post-card-wrap">
            <a class="post-card" href="/{{../platform}}/post/{{this.slug}}">
              {{#if this.coverImage}}
                <img class="post-card-img" src="{{this.coverImage}}" alt="{{this.title}}" loading="lazy" width="400" height="200">
              {{else}}
                <div class="post-card-img-placeholder"><i class="bi bi-file-earmark-text"></i></div>
              {{/if}}
              <div class="post-card-body">
                <span class="post-card-platform">{{#if (eq ../platform 'skillsminds')}}Skills & Minds{{else}}no Face Thinker{{/if}}</span>
                <h2>{{this.title}}</h2>
                {{#if this.excerpt}}<p>{{this.excerpt}}</p>{{/if}}
              </div>
            </a>
            {{#if ../isPaywall}}<span class="post-card-lock"><i class="bi bi-lock-fill"></i> Premium</span>{{/if}}
          </div>
          {{/each}}
        {{else}}
          <div class="empty-state">
            <i class="bi bi-file-earmark-text"></i>
            <p>No posts yet.</p>
          </div>
        {{/if}}

        {{#if isPaywall}}
        <div class="paywall-wrap">
          <div class="paywall-card">
            <i class="bi bi-star-fill" style="font-size:2.2rem;color:#535da1;display:block;margin-bottom:16px"></i>
            <h2 data-en="Subscribe to read all posts" data-ru="Подпишитесь для полного доступа" data-kk="Барлық постқа қол жеткізу үшін жазылыңыз">Subscribe to read all posts</h2>
            <p data-en="Get full access to all no Face Thinker posts. $3.90/month with a 7-day free trial." data-ru="Получите полный доступ ко всем постам no Face Thinker. $3.90/мес, 7 дней бесплатно." data-kk="no Face Thinker постарының барлығына қол жеткізіңіз. Айына $3.90, 7 күн тегін.">Get full access to all no Face Thinker posts. $3.90/month with a 7-day free trial.</p>
            <button class="btn-thinker" onclick="openThinkerCheckout()">
              <i class="bi bi-star"></i>
              <span data-en="Start 7-day Free Trial" data-ru="7 дней бесплатно" data-kk="7 күн тегін">Start 7-day Free Trial</span>
            </button>
          </div>
        </div>
        {{/if}}
      </div>
    </div>
  </div>

  {{> footer}}
  <script src="/js/jquery.min.js"></script>
  <script src="/js/bootstrap.min.js"></script>
  <script src="/js/jquery.sticky.js"></script>
  <script src="/js/custom.js?v=20260428-profile-i18n"></script>
  {{#if isPaywall}}
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <script>
    Paddle.Environment.set('sandbox');
    Paddle.Initialize({
      token: 'test_16c22427a493b4298c916610736',
      eventCallback: function(event) {
        if (event.name === 'checkout.completed') {
          fetch('/api/paddle/thinker/verify-checkout', { method: 'POST' })
            .then(function() { window.location.reload(); })
            .catch(function() { window.location.reload(); });
        }
      }
    });
    function openThinkerCheckout() {
      Paddle.Checkout.open({ items: [{ priceId: '{{thinkerPriceId}}', quantity: 1 }] });
    }
  </script>
  {{/if}}
</body>
</html>
