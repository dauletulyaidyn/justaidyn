<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <meta name="description" content="{{description}}">
  <link rel="icon" type="image/png" href="/favicon.png?v=20260331c">
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/templatemo-first-portfolio-style.css" rel="stylesheet">
  <style>
    body { background: #f6f8fb; color: #18232c; }
    .app-shell { max-width: 1120px; margin: 0 auto; padding: 150px 24px 80px; }
    .app-hero { display: grid; grid-template-columns: minmax(0, 1fr) 330px; gap: 36px; align-items: center; padding: 36px 0 42px; border-bottom: 1px solid rgba(24,35,44,.1); }
    .app-kicker { color: #535da1; text-transform: uppercase; letter-spacing: .08em; font-size: .78rem; font-weight: 900; margin-bottom: 12px; }
    .app-hero h1 { font-size: clamp(2rem, 4vw, 4rem); line-height: 1; margin: 0 0 16px; letter-spacing: 0; }
    .app-hero p { color: #5e6c79; font-size: 1.05rem; max-width: 720px; margin: 0; }
    .download-panel { background: #fff; border: 1px solid rgba(24,35,44,.1); border-radius: 8px; padding: 22px; box-shadow: 0 16px 36px rgba(24,35,44,.08); }
    .version { font-size: .8rem; color: #7a8793; margin-bottom: 12px; font-weight: 700; }
    .download-btn { display: inline-flex; width: 100%; align-items: center; justify-content: center; gap: 8px; border-radius: 8px; padding: 13px 18px; background: #535da1; color: #fff; font-weight: 900; text-decoration: none; }
    .download-btn:hover { background: #3d4680; color: #fff; }
    .app-section { padding: 38px 0 0; max-width: 820px; }
    .app-section h2 { font-size: 1.35rem; margin-bottom: 12px; }
    .app-section p { color: #53616d; line-height: 1.75; }
    @media (max-width: 991px) { .app-shell { padding-top: 205px; } .app-hero { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <section class="preloader"><div class="spinner"><span class="spinner-rotate"></span></div></section>
  <nav class="navbar navbar-expand-lg navbar-split">
    <div class="container">
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNav"><span class="navbar-toggler-icon"></span></button>
      <a class="navbar-brand mx-auto mx-lg-0" href="/">JustAidyn</a>
      <div class="collapse navbar-collapse" id="appNav">
        <div class="navbar-split-layout w-100">
          <div class="navbar-top-contact d-none d-lg-flex">
            <div class="navbar-top-contact-left"></div>
            <div class="navbar-top-tools">
              <div class="language-selector navbar-top-lang language-flags" role="group" aria-label="Language selector">
                <button type="button" class="lang-flag-btn" data-lang-option="kk" onclick="changeLanguage('kk')" aria-label="Kazakh" title="Kazakh">KK</button>
                <button type="button" class="lang-flag-btn" data-lang-option="en" onclick="changeLanguage('en')" aria-label="English" title="English">EN</button>
                <button type="button" class="lang-flag-btn" data-lang-option="ru" onclick="changeLanguage('ru')" aria-label="Russian" title="Russian">RU</button>
              </div>
              <div class="navbar-top-auth-links"></div>
            </div>
          </div>
          <ul class="navbar-nav ms-lg-0 nav-row-primary">
            {{#each lowerNav}}
            <li class="nav-item"><a class="nav-link {{#if this.active}}active{{/if}}" href="{{this.url}}">{{this.labelEn}}</a></li>
            {{/each}}
          </ul>
        </div>
      </div>
    </div>
  </nav>

  <main class="app-shell">
    <section class="app-hero">
      <div>
        <div class="app-kicker">JustAidyn Apps</div>
        <h1>{{heroTitle}}</h1>
        <p>{{heroText}}</p>
      </div>
      <aside class="download-panel">
        <div class="version">Latest version</div>
        <h2 style="font-size:1.8rem;margin-bottom:14px">Version {{releaseVersion}}</h2>
        <a class="download-btn" href="{{primaryAction.url}}"><i class="bi bi-download"></i> {{primaryAction.label}}</a>
        <div class="version" style="margin-top:14px;margin-bottom:0">Old versions are replaced when a new installer is published.</div>
      </aside>
    </section>

    {{#each sections}}
    <section class="app-section" id="{{this.id}}">
      <h2>{{this.title}}</h2>
      <p>{{this.text}}</p>
    </section>
    {{/each}}
  </main>

  {{> footer}}
  <script src="/js/jquery.min.js"></script>
  <script src="/js/bootstrap.min.js"></script>
  <script src="/js/jquery.sticky.js"></script>
  <script src="/js/custom.js?v=20260428-profile-i18n"></script>
</body>
</html>
