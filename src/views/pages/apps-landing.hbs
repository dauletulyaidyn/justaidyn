<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <meta name="description" content="{{description}}">
  <link rel="icon" type="image/png" href="/favicon.png?v=20260331c">
  <link href="/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/templatemo-first-portfolio-style.css" rel="stylesheet">
  <style>
    :root {
      --apps-ink: #17212b;
      --apps-muted: #607080;
      --apps-primary: #535da1;
      --apps-primary-dark: #3e4781;
      --apps-green: #14b789;
      --apps-line: rgba(23, 33, 43, 0.12);
      --apps-soft: #f5f8fc;
      --apps-shadow: 0 18px 46px rgba(23, 33, 43, 0.10);
    }

    body { background: #f6f8fb; color: var(--apps-ink); }
    .apps-page { padding-top: 112px; overflow: hidden; }
    .apps-band { padding: 74px 24px; }
    .apps-inner { width: min(1140px, 100%); margin: 0 auto; }
    .apps-hero {
      min-height: calc(78vh - 112px);
      display: flex;
      align-items: center;
      background:
        linear-gradient(90deg, rgba(246, 248, 251, 0.98), rgba(246, 248, 251, 0.90) 56%, rgba(246, 248, 251, 0.70)),
        url("/images/generated/apps-hub-bg.png") center / cover no-repeat;
    }
    .apps-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 46px; align-items: center; }
    .apps-kicker { display: inline-flex; align-items: center; gap: 9px; min-height: 32px; padding: 5px 12px; border: 1px solid rgba(83,93,161,.18); border-radius: 8px; background: rgba(255,255,255,.75); color: var(--apps-primary-dark); font-size: .78rem; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; }
    .apps-hero h1 { margin: 22px 0 18px; font-size: clamp(2.4rem, 6vw, 5rem); line-height: 1; letter-spacing: 0; }
    .apps-hero p { max-width: 680px; color: #344353; font-size: 1.08rem; line-height: 1.75; margin: 0 0 28px; }
    .apps-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; }
    .apps-btn { display: inline-flex; align-items: center; justify-content: center; gap: 9px; min-height: 48px; padding: 11px 20px; border-radius: 8px; font-weight: 900; text-decoration: none; border: 1px solid transparent; }
    .apps-btn.primary { background: var(--apps-primary); color: #fff; box-shadow: 0 12px 28px rgba(83,93,161,.23); }
    .apps-btn.primary:hover { background: var(--apps-primary-dark); color: #fff; }
    .apps-btn.secondary { background: rgba(255,255,255,.78); border-color: rgba(83,93,161,.28); color: var(--apps-primary-dark); }
    .apps-btn.secondary:hover { background: #fff; color: var(--apps-primary-dark); }
    .apps-stats { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .apps-stat { padding: 24px; border: 1px solid var(--apps-line); border-radius: 8px; background: rgba(255,255,255,.86); box-shadow: var(--apps-shadow); }
    .apps-stat strong { display: block; font-size: 2.4rem; line-height: 1; color: var(--apps-primary); margin-bottom: 8px; }
    .apps-stat span { color: var(--apps-muted); font-weight: 900; }
    .apps-section-heading { max-width: 760px; margin-bottom: 34px; }
    .apps-section-heading h2 { margin: 12px 0 0; font-size: clamp(1.8rem, 3.8vw, 3rem); line-height: 1.12; }
    .apps-section-heading p { margin: 14px 0 0; color: var(--apps-muted); line-height: 1.75; }
    .apps-white { background: #fff; }
    .apps-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
    .program-card { display: flex; flex-direction: column; border: 1px solid var(--apps-line); border-radius: 8px; background: #fff; overflow: hidden; box-shadow: 0 10px 28px rgba(23,33,43,.06); }
    .program-media { padding: 24px; min-height: 190px; display: grid; place-items: center; background: linear-gradient(135deg, rgba(83,93,161,.12), rgba(20,183,137,.10)); }
    .program-media img { width: min(100%, 280px); height: auto; display: block; filter: drop-shadow(0 14px 26px rgba(23,33,43,.12)); }
    .program-body { padding: 24px; display: flex; flex: 1; flex-direction: column; }
    .program-body h3 { margin: 0 0 10px; font-size: 1.25rem; }
    .program-body p { margin: 0 0 18px; color: var(--apps-muted); line-height: 1.65; }
    .program-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
    .program-pill { display: inline-flex; align-items: center; gap: 7px; min-height: 30px; padding: 5px 10px; border-radius: 8px; background: rgba(83,93,161,.10); color: var(--apps-primary-dark); font-size: .78rem; font-weight: 900; }
    .program-pill.downloads { background: rgba(20,183,137,.12); color: #0e8a63; }
    .program-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: auto; }
    @media (max-width: 991px) {
      .apps-page { padding-top: 190px; }
      .apps-hero { min-height: auto; }
      .apps-hero-grid { grid-template-columns: 1fr; }
      .apps-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 640px) {
      .apps-band { padding: 48px 18px; }
      .apps-grid, .apps-stats { grid-template-columns: 1fr; }
      .apps-actions .apps-btn, .program-actions .apps-btn { width: 100%; }
    }
  </style>
</head>
<body>
  <section class="preloader"><div class="spinner"><span class="spinner-rotate"></span></div></section>
  <nav class="navbar navbar-expand-lg navbar-split">
    <div class="container">
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appsNav"><span class="navbar-toggler-icon"></span></button>
      <a class="navbar-brand mx-auto mx-lg-0" href="/">JustAidyn</a>
      <div class="collapse navbar-collapse" id="appsNav">
        <div class="navbar-split-layout w-100">
          <div class="navbar-top-contact d-none d-lg-flex">
            <div class="navbar-top-contact-left"></div>
            <div class="navbar-top-tools">
              <div class="language-selector navbar-top-lang language-flags" role="group" aria-label="Language selector">
                <button type="button" class="lang-flag-btn" data-lang-option="kk" onclick="changeLanguage('kk')">KK</button>
                <button type="button" class="lang-flag-btn" data-lang-option="en" onclick="changeLanguage('en')">EN</button>
                <button type="button" class="lang-flag-btn" data-lang-option="ru" onclick="changeLanguage('ru')">RU</button>
              </div>
              <div class="navbar-top-auth-links"></div>
            </div>
          </div>
          <ul class="navbar-nav ms-lg-0 nav-row-primary">
            <li class="nav-item"><a class="nav-link active" href="/apps">Apps</a></li>
            <li class="nav-item"><a class="nav-link" href="#programs">Programs</a></li>
            <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
          </ul>
        </div>
      </div>
    </div>
  </nav>

  <main class="apps-page">
    <section class="apps-band apps-hero">
      <div class="apps-inner apps-hero-grid">
        <div>
          <div class="apps-kicker"><i class="bi bi-grid-3x3-gap"></i> JustAidyn Apps</div>
          <h1>Desktop programs from JustAidyn.</h1>
          <p>Download the latest versions, open product pages, and see how often JustAidyn applications have been downloaded.</p>
          <div class="apps-actions">
            <a class="apps-btn primary" href="#programs"><i class="bi bi-window-stack"></i> View programs</a>
            <a class="apps-btn secondary" href="#contact"><i class="bi bi-envelope"></i> Contact</a>
          </div>
        </div>
        <aside class="apps-stats" aria-label="Apps download statistics">
          <div class="apps-stat"><strong>{{appCount}}</strong><span>published programs</span></div>
          <div class="apps-stat"><strong>{{totalDownloads}}</strong><span>total downloads</span></div>
        </aside>
      </div>
    </section>

    <section class="apps-band apps-white" id="programs">
      <div class="apps-inner">
        <div class="apps-section-heading">
          <div class="apps-kicker"><i class="bi bi-download"></i> Programs</div>
          <h2>Latest available applications.</h2>
          <p>Each card shows the current release and the number of tracked downloads from JustAidyn.</p>
        </div>
        <div class="apps-grid">
          {{#each apps}}
          <article class="program-card">
            <div class="program-media">
              <img src="/images/generated/screencam-product-mockup.png" alt="{{this.name}} preview" loading="lazy">
            </div>
            <div class="program-body">
              <h3>{{this.name}}</h3>
              <p>{{this.shortDescription}}</p>
              <div class="program-meta">
                <span class="program-pill"><i class="bi bi-tag"></i> Version {{this.version}}</span>
                <span class="program-pill downloads"><i class="bi bi-download"></i> {{this.downloadCount}} downloads</span>
              </div>
              <div class="program-actions">
                <a class="apps-btn primary" href="{{this.trackUrl}}"><i class="bi bi-download"></i> Download</a>
                <a class="apps-btn secondary" href="{{this.detailUrl}}"><i class="bi bi-arrow-right"></i> Details</a>
              </div>
            </div>
          </article>
          {{/each}}
        </div>
      </div>
    </section>

    <section class="apps-band" id="contact">
      <div class="apps-inner">
        <div class="apps-section-heading">
          <div class="apps-kicker"><i class="bi bi-life-preserver"></i> Contact</div>
          <h2>Need help with an installer or subscription?</h2>
          <p>For support, send your product name, app version, Windows version, and the email used for JustAidyn sign-in.</p>
        </div>
        <div class="apps-actions">
          <a class="apps-btn primary" href="mailto:aidyn.daulet@gmail.com"><i class="bi bi-envelope"></i> Email support</a>
          <a class="apps-btn secondary" href="/refunds"><i class="bi bi-receipt"></i> Refund policy</a>
        </div>
      </div>
    </section>
  </main>

  {{> footer}}
  <script src="/js/jquery.min.js"></script>
  <script src="/js/bootstrap.min.js"></script>
  <script src="/js/jquery.sticky.js"></script>
  <script src="/js/custom.js?v=20260428-profile-i18n"></script>
</body>
</html>
