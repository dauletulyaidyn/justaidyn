<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    <meta name="description" content="{{description}}">
    <link rel="icon" type="image/png" href="/images/aidyn-avatar.jpg">
    <link rel="shortcut icon" type="image/png" href="/images/aidyn-avatar.jpg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Roboto+Slab:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.css" rel="stylesheet">
    <link href="/static/styles/platform.css" rel="stylesheet">
  </head>
  <body class="platform-body">
    {{> header}}
    <main class="platform-main">
      <section class="platform-hero">
        <div class="container">
          <div class="platform-hero-shell">
            {{#if eyebrow}}<div class="platform-eyebrow">{{eyebrow}}</div>{{/if}}
            <h1 class="platform-title">{{heroTitle}}</h1>
            <p class="platform-copy">{{heroText}}</p>
            <div class="platform-actions">
              {{#if primaryAction}}<a class="btn platform-btn" href="{{primaryAction.url}}">{{primaryAction.label}}</a>{{/if}}
              {{#if secondaryAction}}<a class="btn platform-btn platform-btn-secondary" href="{{secondaryAction.url}}">{{secondaryAction.label}}</a>{{/if}}
            </div>
          </div>
        </div>
      </section>

      {{#if cards}}
      <section class="platform-section">
        <div class="container">
          <div class="row g-4">
            {{#each cards}}
              <div class="col-lg-4 col-md-6">
                <article class="platform-card">
                  <h2>{{this.title}}</h2>
                  <p>{{this.text}}</p>
                  {{#if this.href}}<a class="platform-inline-link" href="{{this.href}}">{{this.cta}}</a>{{/if}}
                </article>
              </div>
            {{/each}}
          </div>
        </div>
      </section>
      {{/if}}
    </main>
    {{> footer}}
    <script src="/js/bootstrap.min.js"></script>
  </body>
  </html>
